SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:////data/myapp/app.db
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FORCE_HTTPS=true
VERSION=1.0.0
# FLASK_PORT=5000   # assign a unique dev port per app — see port registry in PATTERNS.md. Omit in production.
# TEST_USER=alice   # bypass Google OAuth in local dev; logs in as fake user 'alice'
